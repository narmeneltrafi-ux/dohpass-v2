VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — DO NOT add to this file.
# It must only be used in Supabase Edge Functions (set via `supabase secrets set`)
# or a server-side backend. Exposing it client-side gives anyone full DB access.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe (publishable key only — safe for client-side)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
